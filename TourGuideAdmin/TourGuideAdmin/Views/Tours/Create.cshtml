@model TourGuideAdmin.Models.Tour

@{
    ViewData["Title"] = "Thêm Tour mới";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>✨ Thêm Tour mới</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">🔙 Quay lại danh sách</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="alert alert-info border-0 shadow-sm">
                <strong>💡 Mẹo tự động:</strong> Giám đốc chỉ cần nhập <b>Tiếng Việt</b>. Hệ thống AI sẽ tự động dịch sang Anh, Trung, Hàn, Nhật ngay khi bấm Lưu!
            </div>

            <div class="row">
                <div class="col-md-5">
                    <div class="form-group mb-3">
                        <label asp-for="Name_VI" class="control-label fw-bold">Tên Tour (Tiếng Việt) <span class="text-danger">*</span></label>
                        <input asp-for="Name_VI" class="form-control" placeholder="VD: Sài Gòn Xưa & Nay" required />
                        <span asp-validation-for="Name_VI" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Thời gian dự kiến</label>
                        <input asp-for="EstimatedTime" class="form-control" placeholder="VD: 3 Giờ" />
                        <span asp-validation-for="EstimatedTime" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Hình ảnh minh họa</label>
                        <input type="file" name="fileHinhAnh" class="form-control" accept="image/*" />
                        <small class="text-muted">Chọn tấm hình đẹp nhất cho Tour này nhé!</small>
                    </div>
                </div>

                <div class="col-md-7">
                    <div class="form-group mb-3 h-100">
                        <label asp-for="Description_VI" class="control-label fw-bold">Thuyết minh Tour (Tiếng Việt)</label>
                        <textarea asp-for="Description_VI" class="form-control" rows="9" placeholder="Nhập lời giới thiệu hoành tráng về lộ trình này..."></textarea>
                        <span asp-validation-for="Description_VI" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <hr class="my-4 text-muted" />
            <div class="form-group text-end">
                <button type="submit" class="btn btn-primary px-5 fw-bold">💾 Lưu & Tự Động Dịch</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}