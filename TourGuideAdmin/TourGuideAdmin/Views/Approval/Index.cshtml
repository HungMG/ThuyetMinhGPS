@model IEnumerable<TourGuideAdmin.Models.POI>

@{
    ViewData["Title"] = "Quản lý Địa điểm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 style="color: #C0502E; font-weight: bold;">🛡️ Quản lý Địa điểm POI</h2>
            <p class="text-muted">Kiểm duyệt và quản lý các địa điểm do người dùng đóng góp.</p>
        </div>
    </div>

    <ul class="nav nav-pills mb-4 gap-2 border-bottom pb-3">
        <li class="nav-item">
            <a class="nav-link @(ViewBag.CurrentStatus == 0 ? "active bg-warning text-dark fw-bold shadow-sm" : "text-secondary border")"
               asp-action="Index" asp-route-status="0">
                ⏳ Đang chờ duyệt <span class="badge bg-danger ms-1">@ViewBag.CountPending</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewBag.CurrentStatus == 1 ? "active bg-success text-white fw-bold shadow-sm" : "text-secondary border")"
               asp-action="Index" asp-route-status="1">
                ✅ Đã lên App <span class="badge bg-light text-success ms-1">@ViewBag.CountApproved</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewBag.CurrentStatus == 2 ? "active bg-danger text-white fw-bold shadow-sm" : "text-secondary border")"
               asp-action="Index" asp-route-status="2">
                ❌ Bị từ chối <span class="badge bg-light text-danger ms-1">@ViewBag.CountRejected</span>
            </a>
        </li>
    </ul>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive bg-white rounded shadow-sm border">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Tên Địa Điểm</th>
                    <th>📍 Loại hình</th>
                    <th>Tọa độ GPS</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center py-5 text-muted fs-5">📭 Không có dữ liệu trong mục này!</td></tr>
                }

                @foreach (var item in Model)
                {
                    // 🌟 BẢN VÁ LỖI TÌM CHÌA KHÓA: Tránh văng App khi ID = 0 (Khách vãng lai)
                    var ownersDict = ViewBag.Owners as Dictionary<int, TourGuideAdmin.Models.User>;
                    // Nếu có trong danh sách thì lấy, không có thì cho là null
                    var owner = (ownersDict != null && ownersDict.ContainsKey(item.OwnerId)) ? ownersDict[item.OwnerId] : null;

                    <tr>
                        <td class="fw-bold text-muted">#@item.Id</td>

                        <td>
                            @if (item.OwnerId == -1)
                            {
                                // Chắc chắn 100% là của Web Admin thêm
                                <span class="badge bg-dark px-3 py-2"><i class="bi bi-shield-check"></i> Hệ thống (Admin)</span>
                            }
                            else if (item.OwnerId == 0)
                            {
                                // Bọn này là Khách không thèm đăng nhập
                                <span class="text-muted">Khách vãng lai</span>
                            }
                            else if (owner != null)
                            {
                                // User chính hiệu có tên tuổi
                                <div class="d-flex flex-column">
                                    <small class="text-muted" style="font-size: 0.7rem;">Đóng góp bởi:</small>
                                    <span class="fw-bold text-primary">👤 @owner.Username</span>
                                </div>
                            }
                        </td>

                        <td>
                            @if (item.PoiType == 1)
                            {
                                <span class="badge bg-primary px-3 py-2">🏢 Doanh Nghiệp</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark px-3 py-2">🌳 Cộng Đồng</span>
                            }
                        </td>

                        <td><small class="text-muted">Lat: @item.Latitude<br />Lng: @item.Longitude</small></td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold">
                                🔍 Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>