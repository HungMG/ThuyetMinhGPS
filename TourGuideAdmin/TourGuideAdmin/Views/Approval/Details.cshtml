@model TourGuideAdmin.Models.POI

@{
    ViewData["Title"] = "Chi tiết thẩm định";
}

<div class="container mt-4">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a asp-action="Index" asp-route-status="@Model.ApprovalStatus" class="btn btn-outline-secondary btn-sm rounded-pill px-3">⬅ Quay lại danh sách</a>

        @if (Model.ApprovalStatus == 0)
        {
            <span class="badge bg-warning text-dark fs-5 shadow-sm px-4 py-2">⏳ ĐANG CHỜ DUYỆT</span>
        }
        else if (Model.ApprovalStatus == 1)
        {
            <span class="badge bg-success fs-5 shadow-sm px-4 py-2">✅ ĐÃ LÊN APP</span>
        }
        else
        {
            <span class="badge bg-danger fs-5 shadow-sm px-4 py-2">❌ ĐÃ BỊ TỪ CHỐI</span>
        }
    </div>
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 bg-dark d-flex justify-content-center align-items-center" style="min-height: 400px;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="~/images/pois/@Model.ImageUrl" class="img-fluid w-100 h-100" style="object-fit: cover;" alt="Ảnh địa điểm">
                }
                else
                {
                    <div class="text-center text-light">
                        <h1 class="display-1">📷</h1>
                        <p>Không có ảnh đính kèm</p>
                    </div>
                }
            </div>

            <div class="col-md-7">
                <div class="card-body p-5">
                    <h2 class="card-title fw-bold mb-4" style="color: #C0502E;">@Model.Name_VI</h2>

                    <div class="mb-4">
                        <h6 class="text-muted fw-bold mb-2">PHÂN LOẠI ĐỊA ĐIỂM:</h6>
                        @if (Model.PoiType == 1)
                        {
                            <div class="p-3 bg-primary bg-opacity-10 border border-primary rounded-3 text-primary fw-bold fs-5">
                                🏢 ĐỊA ĐIỂM KINH DOANH (DOANH NGHIỆP)
                            </div>
                        }
                        else
                        {
                            <div class="p-3 bg-info bg-opacity-10 border border-info rounded-3 text-dark fw-bold fs-5">
                                🌳 ĐỊA ĐIỂM CÔNG CỘNG (CỘNG ĐỒNG)
                            </div>
                        }
                    </div>

                    <p class="text-muted mb-4"><i class="bi bi-person-circle"></i> Người nộp: <strong>@ViewBag.OwnerName</strong></p>

                    <h5 class="fw-bold" style="color: #4A3A31;">📝 Thuyết minh / Mô tả:</h5>
                    <div class="p-3 mb-4 rounded" style="background-color: #FAF7F2; border: 1px solid #E8E0D5;">
                        <p class="mb-0" style="white-space: pre-line;">@(string.IsNullOrEmpty(Model.Description_VI) ? "Không có mô tả." : Model.Description_VI)</p>
                    </div>

                    <h5 class="fw-bold" style="color: #4A3A31;">📍 Tọa độ GPS:</h5>
                    <div class="d-flex gap-3 mb-5">
                        <input type="text" class="form-control bg-light" value="Lat: @Model.Latitude" readonly>
                        <input type="text" class="form-control bg-light" value="Lng: @Model.Longitude" readonly>
                        <a href="https://www.google.com/maps/search/?api=1&query=@Model.Latitude,@Model.Longitude" target="_blank" class="btn btn-outline-info text-nowrap">🗺️ Xem Maps</a>
                    </div>

                    <hr />

                    <div class="d-flex gap-3 mt-4">

                        @if (Model.ApprovalStatus != 1)
                        {
                            <form asp-action="ChangeStatus" method="post" class="flex-grow-1">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="1" />
                                <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5 rounded-pill shadow-sm">
                                    ✅ DUYỆT BÀI NÀY LÊN APP
                                </button>
                            </form>
                        }

                        @if (Model.ApprovalStatus != 2)
                        {
                            <form asp-action="ChangeStatus" method="post" class="flex-grow-1">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="2" />
                                <button type="submit" class="btn btn-outline-danger w-100 py-3 fw-bold fs-5 rounded-pill" onclick="return confirm('Sếp chắc chắn muốn từ chối / gỡ bỏ địa điểm này khỏi App chứ?');">
                                    ❌ TỪ CHỐI / GỠ BỎ
                                </button>
                            </form>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>