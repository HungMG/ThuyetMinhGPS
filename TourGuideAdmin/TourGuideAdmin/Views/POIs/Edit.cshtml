@model TourGuideAdmin.Models.POI

@{
    ViewData["Title"] = "Chỉnh sửa Địa điểm";
}

<h2 class="mb-4">✏️ Chỉnh sửa Địa điểm (POI)</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="LastPlayedTime" /> <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="form-group mb-3">
                        <label asp-for="TourId" class="control-label fw-bold">Thuộc Tour (Mã ID)</label>
                        <input asp-for="TourId" class="form-control" />
                        <span asp-validation-for="TourId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Name_VI" class="control-label fw-bold">Tên Địa Điểm (Tiếng Việt) *</label>
                        <input asp-for="Name_VI" class="form-control" placeholder="Ví dụ: Dinh Độc Lập" />
                        <span asp-validation-for="Name_VI" class="text-danger"></span>
                        <small class="text-success fw-bold">💡 Mẹo: Các ngôn ngữ khác sẽ được tự động dịch khi sếp bấm Lưu!</small>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description_VI" class="control-label fw-bold">Thuyết minh (Tiếng Việt)</label>
                        <textarea asp-for="Description_VI" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description_VI" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body bg-light">
                    <h5 class="card-title">📍 Cấu hình Định vị & Kích hoạt Audio</h5>
                    <div class="row mt-3">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Latitude" class="control-label fw-bold">Vĩ độ (Latitude)</label>
                            <input asp-for="Latitude" class="form-control" />
                            <span asp-validation-for="Latitude" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Longitude" class="control-label fw-bold">Kinh độ (Longitude)</label>
                            <input asp-for="Longitude" class="form-control" />
                            <span asp-validation-for="Longitude" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="TriggerRadius" class="control-label fw-bold">Bán kính kích hoạt (m)</label>
                            <input asp-for="TriggerRadius" class="form-control" placeholder="Ví dụ: 50" />
                            <span asp-validation-for="TriggerRadius" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Priority" class="control-label fw-bold">Độ ưu tiên</label>
                            <input asp-for="Priority" class="form-control" placeholder="1 là cao nhất" />
                            <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group form-check mt-2">
                        <label class="form-check-label fw-bold text-danger">
                            <input class="form-check-input" asp-for="IsFavorite" /> ❤️ Đánh dấu là Địa điểm Nổi bật (Favorite)
                        </label>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-body">
                    <h5 class="card-title text-primary">🖼️ Hình ảnh Đại diện</h5>

                    <div class="mt-3 mb-3">
                        <label class="control-label fw-bold">Ảnh hiện tại đang dùng:</label><br />
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="~/images/pois/@Model.ImageUrl" alt="Hình POI" style="max-height: 150px; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);" />
                        }
                        else
                        {
                            <span class="badge bg-secondary">Chưa có ảnh</span>
                        }
                    </div>

                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="form-group">
                        <label class="control-label fw-bold">Tải ảnh mới lên (Sẽ ghi đè ảnh cũ):</label>
                        <input type="file" name="fileHinhAnh" class="form-control" accept="image/*" />
                        <small class="text-muted">Bỏ trống nếu sếp không muốn thay đổi hình ảnh hiện tại.</small>
                    </div>
                </div>
            </div>

            <div class="form-group mb-5">
                <button type="submit" class="btn btn-success btn-lg px-5 shadow"><i class="bi bi-save"></i> LƯU & CẬP NHẬT DỮ LIỆU</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-3">Hủy & Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}