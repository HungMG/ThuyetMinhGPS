@model IEnumerable<TourGuideAdmin.Models.POI>

@{
    ViewData["Title"] = "Quản lý Địa điểm";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📍 Danh sách Địa điểm (POI)</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm Địa điểm mới</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Tour ID</th>
                        <th>Tên Địa Điểm (VI)</th>
                        <th>Vĩ độ (Lat)</th>
                        <th>Kinh độ (Lng)</th>
                        <th>Bán kính (m)</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">Tour @Html.DisplayFor(modelItem => item.TourId)</span>
                            </td>
                            <td class="fw-bold text-primary">
                                @Html.DisplayFor(modelItem => item.Name_VI)
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.Latitude)</td>
                            <td>@Html.DisplayFor(modelItem => item.Longitude)</td>
                            <td>@Html.DisplayFor(modelItem => item.TriggerRadius)</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">✏️ Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">📄 Chi tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">🗑️ Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>