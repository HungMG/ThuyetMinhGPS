<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.MainPage">

    <Grid RowDefinitions="Auto,*" Padding="20">

        <Label Grid.Row="0" 
               Text="Danh sách Điểm đến (Test DB)" 
               FontSize="22" 
               FontAttributes="Bold" 
               Margin="0,0,0,20"/>

        <CollectionView Grid.Row="1" x:Name="poiListView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,10" Padding="15" CornerRadius="8" BackgroundColor="#F0F0F0">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="Black"/>

                            <Label Text="{Binding Description}" 
                                   FontSize="16" 
                                   TextColor="DimGray"
                                   Margin="0,4,0,0"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>