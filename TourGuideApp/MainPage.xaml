<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lang="clr-namespace:TourGuideApp.Resources.Languages"
             x:Class="TourGuideApp.MainPage"
             BackgroundColor="#FAF7F2"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,50,20,20" BackgroundColor="White">
            <VerticalStackLayout>
                <Label Text="{x:Static lang:AppLang.ExploreTitle}" FontSize="30" FontAttributes="Bold" TextColor="#4A3A31" FontFamily="Serif"/>
                <Label Text="{x:Static lang:AppLang.ExploreSubtitle}" FontSize="15" TextColor="#8D7A6D"/>
            </VerticalStackLayout>
            <Picker x:Name="NarrationLangPicker" Grid.Column="1" WidthRequest="140" TextColor="#C0502E" TitleColor="#8D7A6D" FontAttributes="Bold" Title="Giọng đọc">
                <Picker.Items>
                    <x:String>🇻🇳 Tiếng Việt</x:String>
                    <x:String>🇬🇧 English</x:String>
                    <x:String>🇨🇳 中文</x:String>
                    <x:String>🇰🇷 한국어</x:String>
                    <x:String>🇯🇵 日本語</x:String>
                </Picker.Items>
            </Picker>
        </Grid>

        <RefreshView x:Name="mainRefreshView" Grid.Row="1" Refreshing="OnRefreshing" RefreshColor="#C0502E">

            <ScrollView>
                <VerticalStackLayout Spacing="20" Padding="0,20,0,40">

                    <Frame Margin="20,10"
                           Padding="0"
                           CornerRadius="20"
                           BackgroundColor="White"
                           HasShadow="False">

                           <SearchBar
                                    Placeholder="Tìm lộ trình, địa điểm..."
                                    BackgroundColor="Transparent"
                                    TextColor="#4A3A31"
                                    PlaceholderColor="#8D7A6D"
                                    CancelButtonColor="#C0502E"
                                    TextChanged="OnSearchTextChanged"
                                    SearchButtonPressed="OnSearchButtonPressed"/>

                    </Frame>

                    <Label Text="{x:Static lang:AppLang.FeaturedTours}" FontSize="20" FontAttributes="Bold" TextColor="#4A3A31" Margin="20,0"/>

                    <CollectionView x:Name="tourListView" SelectionMode="Single" SelectionChanged="OnTourSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame WidthRequest="280" Margin="20,0,0,0" Padding="0" CornerRadius="16" HasShadow="True" BorderColor="Transparent" IsClippedToBounds="True">
                                    <Grid RowDefinitions="140, Auto">

                                        <Image Grid.Row="0" Source="{Binding FullImageUrl, TargetNullValue='img_tour_default.jpg', FallbackValue='img_tour_default.jpg'}" Aspect="AspectFill" BackgroundColor="#D3C9C1"/>

                                        <Frame Grid.Row="0" HorizontalOptions="End" VerticalOptions="Start" Margin="15" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#C0502E" Padding="0">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTourPlayAudioTapped" CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>
                                            <Label Text="▶" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" Margin="2,0,0,0"/>
                                        </Frame>
                                        <VerticalStackLayout Grid.Row="1" Padding="20">
                                            <Label Text="{Binding Name_VI}" FontSize="18" FontAttributes="Bold" TextColor="#4A3A31"/>
                                            <HorizontalStackLayout Margin="0,5,0,0" Spacing="5">
                                                <Label Text="⏱️" FontSize="14"/>
                                                <Label Text="{Binding EstimatedTime}" FontSize="14" FontAttributes="Bold" TextColor="#C0502E"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{x:Static lang:AppLang.FreeExploration}" FontSize="20" FontAttributes="Bold" TextColor="#4A3A31" Margin="20,20,20,0"/>

                    <CollectionView x:Name="poiListView" SelectionMode="Single" SelectionChanged="OnPoiSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="20,0,20,15" Padding="15" CornerRadius="16" HasShadow="False" BorderColor="#E8E0D5" BackgroundColor="White">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                        <Image Grid.Column="0" WidthRequest="70" HeightRequest="70" Aspect="AspectFill" 
       Source="{Binding FullImageUrl, TargetNullValue='img_poi_default.jpg', FallbackValue='img_poi_default.jpg'}">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="12" Rect="0,0,70,70"/>
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Name_VI}" FontSize="16" FontAttributes="Bold" TextColor="#4A3A31"/>
                                            <Label Text="{Binding Description_VI}" FontSize="13" TextColor="#8D7A6D" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,4,0,0"/>
                                        </VerticalStackLayout>
                                        <Frame Grid.Column="2" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#C0502E" Padding="0" VerticalOptions="Center">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPoiPlayAudioTapped" CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>
                                            <Label Text="▶" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" Margin="2,0,0,0"/>
                                        </Frame>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>