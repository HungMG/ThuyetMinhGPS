<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TourGuideApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TourGuideApp"
    xmlns:views="clr-namespace:TourGuideApp.Views" 
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#FFFFFF"
    Shell.TabBarTitleColor="#C0502E"
    Shell.TabBarUnselectedColor="#999999">

    <TabBar>
        <Tab Title="Bản đồ" Icon="map_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" />
        </Tab>

        <Tab Title="Điểm" Icon="pin_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="QR" Icon="qr_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        <Tab Title="Càiđặt" Icon="settings_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>