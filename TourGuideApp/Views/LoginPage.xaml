<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.Views.LoginPage"
             Title="Đăng Nhập"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30,50,30,30" VerticalOptions="Center">

            <Label Text="🧭" FontSize="70" HorizontalOptions="Center" Margin="0,0,0,10"/>
            <Label Text="Tour Guide App" FontSize="28" FontAttributes="Bold" TextColor="#C0502E" HorizontalOptions="Center"/>
            <Label Text="Khám phá thế giới theo cách của bạn" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <Frame CornerRadius="15" HasShadow="True" Padding="20" BackgroundColor="White" BorderColor="#E8E0D5">
                <VerticalStackLayout Spacing="15">

                    <Border Stroke="#E8E0D5" StrokeThickness="1" BackgroundColor="#F8F9FA" Padding="10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Entry x:Name="txtUsername" Placeholder="Tên đăng nhập" TextColor="#2C3E50" ClearButtonVisibility="WhileEditing"/>
                    </Border>

                    <Border Stroke="#E8E0D5" StrokeThickness="1" BackgroundColor="#F8F9FA" Padding="10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Entry x:Name="txtPassword" Placeholder="Mật khẩu" IsPassword="True" TextColor="#2C3E50" ClearButtonVisibility="WhileEditing"/>
                    </Border>

                    <Button x:Name="btnLogin" Text="Đăng Nhập" FontAttributes="Bold" CornerRadius="25"
                            BackgroundColor="#C0502E" TextColor="White" Margin="0,10,0,0"
                            Clicked="OnLoginClicked"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="Chưa có tài khoản?" TextColor="#7F8C8D" VerticalOptions="Center"/>
                        <Label Text="Đăng ký ngay" TextColor="#F39C12" FontAttributes="Bold" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*, Auto, *" Margin="0,20">
                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#D5DBDB" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text=" HOẶC " TextColor="#BDC3C7" FontSize="12" Margin="10,0"/>
                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#D5DBDB" VerticalOptions="Center"/>
            </Grid>

            <Button x:Name="btnAnonymous" Text="Khám Phá Ngay (Ẩn Danh)" FontAttributes="Bold" CornerRadius="25"
                    BackgroundColor="#BDC3C7" TextColor="#2C3E50"
                    Clicked="OnAnonymousClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>