<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:bs="http://pluginmauibottomsheet.com"
             xmlns:lang="clr-namespace:TourGuideApp.Resources.Languages"
             x:Class="TourGuideApp.Views.MapPage"
             Title="Bản đồ"
             Shell.NavBarIsVisible="False">

    <Grid>
        <mapsui:MapView x:Name="tourMap" 
                        VerticalOptions="Fill" 
                        HorizontalOptions="Fill"
                        PinClicked="TourMap_PinClicked"/>

        <Frame WidthRequest="55" HeightRequest="55" CornerRadius="27.5" BackgroundColor="White" 
               HorizontalOptions="End" VerticalOptions="End" Margin="0, 0, 20, 20" 
               HasShadow="True" Padding="0">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCenterLocationTapped"/>
            </Frame.GestureRecognizers>
            <Label Text="🎯" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Frame>

        <Grid ColumnDefinitions="*, Auto" Margin="15,20,15,0" VerticalOptions="Start">
            <Frame Padding="0" CornerRadius="25" HasShadow="True" BackgroundColor="White" BorderColor="#E8E0D5">
                <SearchBar x:Name="mapSearchBar"
                           Placeholder="{x:Static lang:AppLang.SearchPlaceholder}"
                           TextColor="#4A3A31" PlaceholderColor="Gray" 
                           BackgroundColor="Transparent" CancelButtonColor="#C0502E"
                           SearchButtonPressed="OnSearchButtonPressed"
                           TextChanged="OnSearchBarTextChanged"/>
            </Frame>
        </Grid>

        <bs:BottomSheet x:Name="poiDetailPopup" IsOpen="False" HasHandle="True" IsModal="True" CornerRadius="24">
            <bs:BottomSheetContent>
                <bs:BottomSheetContent.Content>
                    <!-- Grid bọc ngoài để chồng QR panel lên nội dung chính -->
                    <Grid HeightRequest="550">

                        <!-- ── NỘI DUNG CHÍNH ── -->
                        <Grid RowDefinitions="Auto, *, Auto" Padding="20" BackgroundColor="White">

                            <VerticalStackLayout Grid.Row="0" Spacing="10">
                                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E8E0D5" HorizontalOptions="Center" Margin="0,0,0,10"/>
                                <Frame HeightRequest="150" CornerRadius="16" HasShadow="False" Padding="0" BorderColor="#E8E0D5">
                                    <Image x:Name="imgPoiImage" Aspect="AspectFill" Source="img_default_poi.png"/>
                                </Frame>

                                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                                    <Label Grid.Column="0" x:Name="lblPoiName" Text="Tên địa điểm..." FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" MaxLines="2" LineBreakMode="TailTruncation"/>
                                    <Frame Grid.Column="1" WidthRequest="40" HeightRequest="40" CornerRadius="20" Padding="0" HasShadow="False" BackgroundColor="#F8F9FA" BorderColor="#E8E0D5" VerticalOptions="Center">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFavoriteTapped"/>
                                        </Frame.GestureRecognizers>
                                        <Label x:Name="lblFavoriteIcon" Text="🤍" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                </Grid>

                                <Label x:Name="lblPoiAddress" Text="..." FontSize="13" TextColor="#7F8C8D"/>

                                <Grid ColumnDefinitions="Auto, *" Margin="0,5">
                                    <Label Text="{x:Static lang:AppLang.ReadLanguage}" VerticalOptions="Center" FontSize="13" TextColor="#8D7A6D"/>
                                    <Picker x:Name="PopupLangPicker" Grid.Column="1" Margin="10,0,0,0" 
                                            Title="{x:Static lang:AppLang.SelectLanguage}" 
                                            TextColor="#C0502E" FontAttributes="Bold"
                                            SelectedIndexChanged="OnPopupLangChanged">
                                        <Picker.Items>
                                            <x:String>🇻🇳 Tiếng Việt</x:String>
                                            <x:String>🇬🇧 English</x:String>
                                            <x:String>🇨🇳 中文</x:String>
                                            <x:String>🇰🇷 한국어</x:String>
                                            <x:String>🇯🇵 日本語</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="#F0F0F0"/>
                            </VerticalStackLayout>

                            <ScrollView Grid.Row="1" Margin="0,10">
                                <Label x:Name="lblPoiDescription" Text="Mô tả..." FontSize="14" TextColor="#34495E" LineHeight="1.4"/>
                            </ScrollView>

                            <Grid Grid.Row="2" ColumnDefinitions="*, Auto, *" ColumnSpacing="10" Padding="0,10,0,0">
                                <Button Grid.Column="0" x:Name="btnReadAudio" Text="{x:Static lang:AppLang.ListenAudio}" 
                                        BackgroundColor="#F39C12" TextColor="White" FontAttributes="Bold"
                                        CornerRadius="25" Clicked="OnReadDescriptionClicked" />
                                <Frame Grid.Column="1" WidthRequest="50" HeightRequest="50" CornerRadius="25"
                                       Padding="0" HasShadow="False" BackgroundColor="#2ECC71" BorderColor="Transparent"
                                       VerticalOptions="Center">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnShowQRTapped"/>
                                    </Frame.GestureRecognizers>
                                    <Label Text="QR" FontSize="15" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="White" HorizontalTextAlignment="Center"/>
                                </Frame>
                                <Button Grid.Column="2" Text="{x:Static lang:AppLang.MapsExternal}" 
                                        BackgroundColor="#C0502E" TextColor="White" FontAttributes="Bold"
                                        CornerRadius="25" Clicked="OnNavigationClicked" />
                            </Grid>
                        </Grid>

                        <!-- ── QR PANEL: chồng lên nội dung chính, ẩn mặc định ── -->
                        <Grid x:Name="qrOverlay" IsVisible="False" BackgroundColor="#E0FFFFFF">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQrOverlayTapped"/>
                            </Grid.GestureRecognizers>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="24">
                                <Label x:Name="lblQrPoiName" Text="Mã QR địa điểm"
                                       FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"
                                       HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation"/>
                                <Frame CornerRadius="16" Padding="8" HasShadow="True"
                                       BorderColor="#E8E0D5" HorizontalOptions="Center"
                                       BackgroundColor="White"
                                       WidthRequest="230" HeightRequest="230" IsClippedToBounds="True">
                                    <!-- 🌟 PNG sinh bởi QRCoder — đúng tham số như Admin -->
                                    <Image x:Name="imgQrCode" Aspect="AspectFit"
                                           WidthRequest="210" HeightRequest="210"
                                           BackgroundColor="White"/>
                                </Frame>
                                <Label Text="Quét để xem thuyết minh tự động" FontSize="13"
                                       TextColor="#8D7A6D" HorizontalTextAlignment="Center"/>
                                <Button Text="← Quay lại" BackgroundColor="#2ECC71" TextColor="White"
                                        FontAttributes="Bold" CornerRadius="22" HeightRequest="46"
                                        WidthRequest="160" HorizontalOptions="Center"
                                        Clicked="OnCloseQrTapped"/>
                            </VerticalStackLayout>
                        </Grid>

                    </Grid>
                </bs:BottomSheetContent.Content>
            </bs:BottomSheetContent>
        </bs:BottomSheet>


    </Grid>
</ContentPage>